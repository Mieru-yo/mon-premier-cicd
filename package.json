{
  "name": "mon-premier-cicd",
  "version": "1.0.0",
  "description": "",
  "main": "index.js",
  "scripts": {
    "test": "jest",
    "test:ci": "jest --ci --coverage --coverageReporters=lcov,text,json-summary",
    "test:watch": "jest --watch",
    "lint": "eslint src/**/*.js",
    "lint:fix": "eslint src/**/*.js --fix"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/Mieru-yo/mon-premier-cicd.git"
  },
  "keywords": [],
  "author": "",
  "license": "ISC",
  "type": "commonjs",
  "bugs": {
    "url": "https://github.com/Mieru-yo/mon-premier-cicd/issues"
  },
  "homepage": "https://github.com/Mieru-yo/mon-premier-cicd#readme",
  "jest": {
    "testEnvironment": "node",
    "collectCoverageFrom": [
      "src/**/*.js",
      "!src/server.js"
    ],
    "coverageThreshold": {
      "global": {
        "branches": 80,
        "functions": 80,
        "lines": 80,
        "statements": 80
      }
    },
    "coverageReporters": [
      "lcov",
      "text",
      "json-summary"
    ]
  },
  "devDependencies": {
    "eslint": "8.57.1",
    "jest": "^30.0.0"
  }
}
